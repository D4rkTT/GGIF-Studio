{
  "name": "gg-gif-oled",
  "version": "0.1.0",
  "description": "Animate GIFs on SteelSeries Arctis Nova Pro OLED via GameSense SDK",
  "author": "GGIF",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win",
    "pack:all": "electron-vite build && electron-builder -mw"
  },
  "dependencies": {
    "gifuct-js": "^2.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  },
  "build": {
    "appId": "com.ggif.oled",
    "productName": "GGIF Studio",
    "directories": { "output": "release" },
    "files": ["out/**/*"],
    "mac": { "target": "dmg", "category": "public.app-category.utilities" },
    "win": { "target": "nsis" }
  }
}
